# Database
DATABASE_URL=postgresql://user:password@localhost:5432/adrena_royale

# Adrena Data API
ADRENA_API_BASE_URL=https://datapi.adrena.trade

# Adrena Competition Service (required)
ADRENA_COMPETITION_API_URL=https://adrena-competition-service.onrender.com
ADRENA_COMPETITION_API_KEY=your_api_key_here

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Treasury (for SOL stake entries)
TREASURY_WALLET=your_multisig_wallet_address

# Admin wallets (comma-separated)
ADMIN_WALLETS=wallet1,wallet2

# Server
PORT=3001
NODE_ENV=development
